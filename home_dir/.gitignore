# Local .terraform directories
.terraform/

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude sensitive .tfvars files, but allow terraform.tfvars (non-sensitive configuration)
# Note: terraform.tfvars files in this repo contain environment-specific but non-sensitive
# configuration values and should be tracked in version control
*.tfvars
*.tfvars.json
# Include terraform.tfvars files (override the above exclusion)
!terraform.tfvars
!global-vars.tfvars
# Exclude specific files with sensitive data (like API keys)
terraform/agentic-dev/06-langgraph/terraform.tfvars

# Ignore override files as they are usually used to override resources locally and so
# are not checked in
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore transient lock info files created by terraform apply
.terraform.tfstate.lock.info
.terraform.lock.hcl

# Include override files you do wish to add to version control using negated pattern
# !example_override.tf

# Ignore plan files (output of terraform plan -out=<file>)
*.plan
*tfplan*

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Temporary and build files
*.zip
*.tar.gz
*.log
*.tmp
*.bak
*.backup
kubeconfig*
errored.tfstate
.DS_Store
Thumbs.db
*.swp
*.swo

# SSH keys and credentials
.ssh/
*.pem
*.key

# Migration and temporary scripts
migrate-*.sh
*-temp.sh
validate.sh
*_ANALYSIS.md

# Reference directories - keep as local references but don't track in repo
reference*/
.vscode/settings.json

# VS Code workspace files - keep as local preferences
*.code-workspace
